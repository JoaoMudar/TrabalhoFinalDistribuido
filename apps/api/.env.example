# Configuração da API — copie para .env e ajuste se necessário.
# Os defaults já funcionam dentro do docker-compose.

PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Banco de dados
MONGO_URL=mongodb://mongo:27017/ingressos
REDIS_URL=redis://redis:6379

# AWS / LocalStack (dev). Em produção, deixe AWS_ENDPOINT_URL vazio.
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
