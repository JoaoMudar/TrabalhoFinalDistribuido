{
  "name": "plataforma-ingressos",
  "version": "0.0.0",
  "private": true,
  "description": "Plataforma de venda de ingressos com tratamento de picos de acesso (trabalho de Sistemas Distribuídos - AWS)",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:worker": "npm run dev --workspace apps/worker",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
